{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "baseUrl": ".",
    "paths": { "@/*": ["src/renderer/src/*"] },
    "types": ["node"]
  },
  "include": ["src/renderer/src/**/*", "src/preload/index.d.ts"]
}
