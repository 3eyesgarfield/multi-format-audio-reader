{
  "name": "polyglot-reader",
  "version": "0.1.0",
  "description": "本地多格式有声阅读器 — PDF / Markdown / EPUB with Huihui + Kokoro + Edge TTS",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "pack:dir": "electron-vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "epubjs": "^0.3.93",
    "i18next": "^23.11.5",
    "markdown-it": "^14.1.0",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "com.polyglot.reader",
    "productName": "Polyglot Reader",
    "files": ["out/**/*"],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!.venv/Lib/site-packages/torch/**",
          "!.venv/Lib/site-packages/torchgen/**",
          "!.venv/Lib/site-packages/functorch/**",
          "!.venv/Lib/site-packages/sympy/**",
          "!.venv/Lib/site-packages/mpmath/**",
          "!.venv/Lib/site-packages/networkx/**",
          "!.venv/Lib/site-packages/scipy/**",
          "!.venv/Lib/site-packages/transformers/**",
          "!.venv/Lib/site-packages/tokenizers/**",
          "!.venv/Lib/site-packages/huggingface_hub/**",
          "!.venv/Lib/site-packages/hf_xet/**",
          "!.venv/Lib/site-packages/safetensors/**",
          "!.venv/Lib/site-packages/spacy/**",
          "!.venv/Lib/site-packages/spacy_legacy/**",
          "!.venv/Lib/site-packages/spacy_loggers/**",
          "!.venv/Lib/site-packages/spacy_curated_transformers/**",
          "!.venv/Lib/site-packages/thinc/**",
          "!.venv/Lib/site-packages/blis/**",
          "!.venv/Lib/site-packages/wasabi/**",
          "!.venv/Lib/site-packages/srsly/**",
          "!.venv/Lib/site-packages/catalogue/**",
          "!.venv/Lib/site-packages/cymem/**",
          "!.venv/Lib/site-packages/preshed/**",
          "!.venv/Lib/site-packages/murmurhash/**",
          "!.venv/Lib/site-packages/confection/**",
          "!.venv/Lib/site-packages/langcodes/**",
          "!.venv/Lib/site-packages/weasel/**",
          "!.venv/Lib/site-packages/jieba/**",
          "!.venv/Lib/site-packages/pypinyin/**",
          "!.venv/Lib/site-packages/pypinyin_dict/**",
          "!.venv/Lib/site-packages/cn2an/**",
          "!.venv/Lib/site-packages/misaki/**",
          "!.venv/Lib/site-packages/kokoro/**",
          "!.venv/Lib/site-packages/espeakng_loader/**",
          "!.venv/Lib/site-packages/cv2/**",
          "!.venv/Lib/site-packages/onnxruntime/**",
          "!.venv/Lib/site-packages/rapidocr_onnxruntime/**",
          "!.venv/Lib/site-packages/PIL/**",
          "!.venv/Lib/site-packages/shapely/**",
          "!.venv/Lib/site-packages/shapely.libs/**",
          "!.venv/Lib/site-packages/pyclipper/**",
          "!.venv/Lib/site-packages/rdflib/**",
          "!.venv/Lib/site-packages/babel/**"
        ]
      },
      { "from": "resources/dict", "to": "dict", "filter": ["**/*", "!*.md"] },
      { "from": "node_modules/pdfjs-dist/standard_fonts", "to": "pdfjs/standard_fonts" },
      { "from": "node_modules/pdfjs-dist/cmaps", "to": "pdfjs/cmaps" }
    ],
    "asar": true,
    "win": { "target": ["nsis"] }
  }
}
